{
	"info": {
		"_postman_id": "admin-api-collection",
		"name": "Admin API Testing Collection",
		"description": "Comprehensive testing collection for Admin Management APIs including signup, login, and organization management",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Main Admin Signup",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has required fields', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('message');",
									"    pm.expect(jsonData).to.have.property('type', 'main_admin');",
									"    pm.expect(jsonData).to.have.property('admin');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Super Admin\",\n    \"email\": \"superadmin@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/admin/main-signup",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"main-signup"
							]
						}
					},
					"response": []
				},
				{
					"name": "Normal Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has token', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('token');",
									"    pm.expect(jsonData).to.have.property('type', 'normal_admin');",
									"});",
									"",
									"// Store token for future requests",
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.collectionVariables.set('normalAdminToken', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"superadmin@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/admin/normal-login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"normal-login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Organization Admin Signup",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has required fields', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('message');",
									"    pm.expect(jsonData).to.have.property('type', 'organization_admin');",
									"    pm.expect(jsonData).to.have.property('admin');",
									"    pm.expect(jsonData).to.have.property('organization');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Organization Admin\",\n    \"email\": \"orgadmin@example.com\",\n    \"password\": \"password123\",\n    \"organizationId\": \"{{organizationId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/admin/org-signup",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"org-signup"
							]
						}
					},
					"response": []
				},
				{
					"name": "Organization Login (Cross-Search)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has token and organization info', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('token');",
									"    pm.expect(jsonData).to.have.property('type', 'organization_admin');",
									"    pm.expect(jsonData).to.have.property('organization');",
									"});",
									"",
									"// Store token for future requests",
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.collectionVariables.set('orgAdminToken', jsonData.token);",
									"    pm.collectionVariables.set('organizationId', jsonData.organization.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"orgadmin@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/admin/organization-login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"organization-login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Admin Profile",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Profile contains admin data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('admin');",
									"    pm.expect(jsonData.admin).to.have.property('email');",
									"    pm.expect(jsonData.admin).to.have.property('id');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{orgAdminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/admin/profile",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"profile"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Admin Management",
			"item": [
				{
					"name": "Get All Main Admins",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains admins array', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('admins');",
									"    pm.expect(jsonData.admins).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/admin",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get All Organization Admins",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains organization admin data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('admins');",
									"    pm.expect(jsonData).to.have.property('totalOrganizations');",
									"    pm.expect(jsonData).to.have.property('totalAdmins');",
									"    pm.expect(jsonData.admins).to.be.an('array');",
									"});",
									"",
									"// Check if admins have organization info",
									"if (pm.response.code === 200 && pm.response.json().admins.length > 0) {",
									"    const firstAdmin = pm.response.json().admins[0];",
									"    pm.expect(firstAdmin).to.have.property('organization');",
									"    pm.expect(firstAdmin).to.have.property('type', 'organization_admin');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/admin/all-organization-admins",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"all-organization-admins"
							]
						}
					},
					"response": []
				},
				{
					"name": "Find Admin by Organization ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains admin data for organization', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('admins');",
									"    pm.expect(jsonData.admins).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/admin/{{organizationId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"{{organizationId}}"
							]
						}
					},
					"response": []
				}
			]
		},
